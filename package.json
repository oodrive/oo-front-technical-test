{
  "name": "oo-front-technical-test",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "mock-server":"json-server --watch db.json --port 3000 --delay 1000",
    "build": "ng build --configuration production",
    "test": "ng test",
    "test:coverage": "ng test --configuration coverage",
    "lint": "ng lint && npm run lint:scss",
    "lint:scss": "stylelint src/**/*.scss",
    "ncu": "npm run update-deps",
    "update-deps": "npm run update-deps:update && npm run update-deps:commit",
    "update-deps:update": "ncu -i",
    "update-deps:commit": "git add package.json package-lock.json && git ci -m 'chore: bump up dependencies' || true",
    "version": "npm run -s version:check && npm run -s version:changelog && git add -A",
    "version:check": "npm run lint && npm test && npm run build",
    "version:changelog": "conventional-changelog -i CHANGELOG.md -s -r 0 -p angular",
    "postversion": "git push && git push --tags",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.scss": [
      "stylelint"
    ],
    "*.ts": [
      "eslint --no-ignore --max-warnings 0"
    ],
    "*.html": [
      "eslint --max-warnings 0"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@oodrive/ng-core": "^2.1.0",
    "json-server": "^0.17.4",
    "moment": "^2.30.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "19.7.1",
    "eslint": "^9.28.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "oo-dot-files": "5.4.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "8.33.1"
  },
  "engines": {
    "node": ">= 20.16",
    "npm": ">= 10.8"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "last 2 Safari versions",
    "last 2 iOS versions",
    "last 2 Android versions",
    "last 2 ChromeAndroid versions",
    "last 2 FirefoxAndroid versions"
  ]
}
